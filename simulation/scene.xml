<mujoco model="yam_workbench">
  <compiler angle="radian" meshdir="assets/" texturedir="assets/"/>

  <option gravity="0 0 -9.81" timestep="0.0005" integrator="implicitfast"
          solver="Newton" iterations="30" cone="elliptic" noslip_iterations="10"/>

  <statistic center="0 0 -0.3" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
  </visual>

  <asset>
    <!-- Workbench visual mesh (UV-mapped, textured from splat colors) -->
    <mesh name="workbench_visual" file="workbench_visual.obj"/>

    <!-- Workbench texture baked from Gaussian splat colors -->
    <texture name="workbench_tex" type="2d" file="workbench_visual.png"/>
    <material name="workbench_mat" texture="workbench_tex"/>

    <!-- Textures -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
      width="512" height="3072"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <light pos="1 1 0.5" dir="-0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>

    <!-- Workbench scene (static) -->
    <body name="workbench" pos="0 0 0">
      <!-- Visual mesh (no collision) — textured from Gaussian splat -->
      <geom name="workbench_visual" type="mesh" mesh="workbench_visual"
            material="workbench_mat" contype="0" conaffinity="0" group="1"/>

      <!-- Collision: table surface -->
      <geom name="table_top" type="box" size="0.6 0.5 0.02"
            pos="0 0 -0.43" rgba="0 0 0 0" group="3"
            contype="1" conaffinity="1" friction="1 0.005 0.0001"/>

      <!-- Collision: floor -->
      <geom name="floor" type="plane" size="3 5 0.01"
            pos="0 0 -1.10" rgba="0 0 0 0" group="3"
            contype="1" conaffinity="1"/>

      <!-- Collision: back wall -->
      <geom name="back_wall" type="box" size="1.4 0.02 1.2"
            pos="0 -2.0 0" rgba="0 0 0 0" group="3"
            contype="1" conaffinity="1"/>

      <!-- Collision: side walls -->
      <geom name="left_wall" type="box" size="0.02 1.5 1.2"
            pos="-1.43 -0.5 0" rgba="0 0 0 0" group="3"
            contype="1" conaffinity="1"/>
      <geom name="right_wall" type="box" size="0.02 1.5 1.2"
            pos="1.43 -0.5 0" rgba="0 0 0 0" group="3"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
